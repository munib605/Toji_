# Copy this to .env for local dev (npm run dev:server).
# In Vercel, add each of these under Project Settings → Environment Variables
# instead — never commit a real .env file.

NODE_ENV=production
API_PREFIX=/api

# Same-origin on Vercel (frontend + API share one domain), so this mostly
# matters for local dev. Set it to your deployed URL once you have one,
# e.g. https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# --- MongoDB ---------------------------------------------------------------
# Get this from MongoDB Atlas: Database > Connect > Drivers.
# Looks like: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/portfolio
MONGO_URI=

# --- Auth --------------------------------------------------------------------
# Randomly generated examples below — safe to use as-is, or generate your own
# with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=e466e66d82bffe1c2121827f6a7627da337efae0576e2a196c34d1b0ec8ccaca9b881661cbcafffa78f2ded363f50cac
JWT_REFRESH_SECRET=bf2ced96f240b21a368d14d636c9409dbf5c57a56277749933c9377cf59d3007ef486f016c4940ed35ed3208aeadd62e
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Set this to your Vercel domain (no protocol) once deployed, e.g. your-app.vercel.app
# Only used when NODE_ENV=production; leave blank for local dev.
COOKIE_DOMAIN=

# --- Admin (for seeding an initial dashboard login) -------------------------
ADMIN_NAME=Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Cloudinary (image uploads) — optional, uploads will fail without it ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- SMTP (contact form emails) — optional, emails are logged instead if unset
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@example.com
OWNER_EMAIL=

# --- Rate limiting (defaults are usually fine) ------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
CONTACT_RATE_LIMIT_MAX=5

LOG_LEVEL=info
